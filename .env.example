PORT=3001
GEMINI_API_KEY=
DATA_FILE=./data/history.json

# Optional OpenRouter key file override
# You can keep OPENROUTER_API_KEY in .env.openrouter instead.
OPENROUTER_API_KEY=

# Optional LLM settings
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=google/gemma-4-31b-it:free
LOCAL_LLM_MODEL=gemma4:e2b

# Optional ML sentiment settings
ENABLE_ML_SENTIMENT=true
SENTIMENT_MODEL=Xenova/distilbert-base-uncased-finetuned-sst-2-english
SENTIMENT_MAX_CHARS=512
